<?xml version="1.0" encoding="UTF-8"?>
<!--
  main_tree.xml — Mowgli BehaviorTree.CPP v4 main tree

  State constants (HighLevelStatus.msg):
    HIGH_LEVEL_STATE_NULL           = 0
    HIGH_LEVEL_STATE_IDLE           = 1
    HIGH_LEVEL_STATE_AUTONOMOUS     = 2
    HIGH_LEVEL_STATE_RECORDING      = 3
    HIGH_LEVEL_STATE_MANUAL_MOWING  = 4

  HighLevelControl commands (HighLevelControl.srv):
    COMMAND_START      = 1
    COMMAND_HOME       = 2
    COMMAND_RECORD_AREA = 3   (area recording)
    COMMAND_S2         = 4   (mow next area)
    COMMAND_MANUAL_MOW = 7
-->
<root BTCPP_format="4" main_tree_to_execute="MowgliMain">

  <BehaviorTree ID="MowgliMain">
    <ReactiveSequence name="Root">

      <!-- ================================================================
           GUARD 1: Emergency (always checked, highest priority)
           Polls every 1s. If the robot is placed back on the dock
           (charging detected), automatically send an emergency release
           to the firmware. The firmware is the safety authority and
           will only clear the latch if the physical trigger (lift/stop
           button) is no longer asserted.
           ================================================================ -->
      <Fallback name="EmergencyGuard">
        <Inverter><IsEmergency/></Inverter>
        <Sequence name="EmergencyHandler">
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="0" state_name="EMERGENCY"/>
          <Fallback name="AutoResetOrWait">
            <!-- If charging (on dock), auto-reset emergency -->
            <Sequence name="DockAutoReset">
              <IsCharging/>
              <ResetEmergency/>
              <WaitForDuration duration_sec="1.0"/>
            </Sequence>
            <!-- Not on dock — just wait and re-check -->
            <WaitForDuration duration_sec="1.0"/>
          </Fallback>
        </Sequence>
      </Fallback>

      <!-- ================================================================
           GUARD 2: Two-tier boundary violation
             * Lethal violation (outside area by more than
               lethal_boundary_margin_m, default 0.5m in map_server_node):
               blade + motors operating this far outside the authorised
               zone can cause real damage — emergency stop, wait for
               operator. No automatic recovery.
             * Soft violation (outside area but within the margin):
               attempt to navigate back to the known-inside dock pose.
               If Nav2 can route us back, normal mowing resumes. If it
               can't inside two attempts, escalate to the lethal path.
           The old behaviour was "BackUp 1m up to 5 times", which pushed
           the robot FURTHER along whatever direction it just crossed
           into — today's run ended with the robot ~50 cm past the
           east edge of the polygon, and each recovery BackUp drove it
           another 30 cm in the same wrong direction.
           ================================================================ -->
      <!-- ReactiveFallback re-evaluates from child 0 every tick, so
           IsCharging becoming true mid-wait (e.g. operator redocks the
           robot) aborts the in-progress lethal WaitForDuration and
           releases the guard. A plain Fallback would stick on the
           RUNNING child and never re-check charging. -->
      <ReactiveFallback name="BoundaryGuard">
        <!-- Short-circuit while charging: the robot is physically on the
             dock and cannot drive off, the blade is off, and non-RTK GPS
             drift on idle can falsely put the reported pose outside the
             polygon. No reason to run any boundary handler in that state. -->
        <IsCharging/>
        <!-- Short-circuit during manual mowing (COMMAND_MANUAL_MOW = 7),
             area recording (COMMAND_RECORD_AREA = 3), and going home
             (COMMAND_HOME = 2). In all three modes the destination is
             expected to lie outside the mowing polygon (joystick area
             for manual/record, dock for home), so a boundary handler
             would fire spuriously and cancel DockRobot mid-approach,
             which is what was breaking auto-redock. The blade is still
             governed by firmware safety, and collision_monitor still
             stops for physical obstacles. -->
        <IsCommand command="7"/>
        <IsCommand command="3"/>
        <IsCommand command="2"/>
        <Inverter><IsBoundaryViolation/></Inverter>

        <!-- Lethal path: stop immediately, latch -->
        <Sequence name="LethalBoundaryHandler">
          <IsLethalBoundaryViolation/>
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="0" state_name="BOUNDARY_EMERGENCY_STOP"/>
          <!-- Hold here forever — operator intervention required. A long
               wait prevents the tree from re-ticking and potentially
               re-issuing goals; the emergency status is visible in the
               GUI so the user knows to recover manually. -->
          <WaitForDuration duration_sec="3600.0"/>
        </Sequence>

        <!-- Soft path: stop, then route back to a known-inside pose -->
        <Sequence name="SoftBoundaryHandler">
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="2" state_name="BOUNDARY_RECOVERY"/>
          <Fallback name="RecoverOrEscalate">
            <!-- Navigate back to the nearest in-area pose. map_server_node's
                 /get_recovery_point picks the closest polygon edge, offsets
                 ~0.8m inward, and faces the robot toward the area. This
                 stays at the mowing location instead of driving all the
                 way home, and avoids the RPP-plans-a-reverse-leg behaviour
                 of DockRobot-based recovery. Two tries before escalating. -->
            <RetryUntilSuccessful num_attempts="2" name="RecoveryRetry">
              <Sequence name="NavigateBackInside">
                <NavigateInsideBoundary/>
                <!-- Succeed only if Nav2 actually put us back inside a
                     defined area. -->
                <Inverter><IsBoundaryViolation/></Inverter>
              </Sequence>
            </RetryUntilSuccessful>
            <!-- Recovery failed — treat as lethal going forward. -->
            <Sequence name="EscalateToEmergency">
              <SetMowerEnabled enabled="false"/>
              <StopMoving/>
              <PublishHighLevelStatus state="0" state_name="BOUNDARY_EMERGENCY_STOP"/>
              <WaitForDuration duration_sec="3600.0"/>
            </Sequence>
          </Fallback>
        </Sequence>
      </ReactiveFallback>

      <!-- ================================================================
           GUARD 3: GPS quality adaptation (reactive)
           ================================================================ -->
      <Fallback name="GPSModeSelector">
        <Sequence name="PreciseMode">
          <IsGPSFixed/>
          <SetNavMode mode="precise"/>
        </Sequence>
        <SetNavMode mode="degraded"/>
      </Fallback>

      <!-- ================================================================
           MAIN LOGIC
           Priority: critical battery → mow → home → record → idle
           ================================================================ -->
      <Fallback name="MainLogic">

        <!-- ============================================================
             a. Critical battery — emergency dock, clear command
             Navigation failure is non-fatal (stay where we are).
             ============================================================ -->
        <Sequence name="CriticalBatteryDock">
          <IsBatteryLow threshold="{battery_critical_pct}" voltage_threshold="{battery_critical_voltage}"/>
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="2" state_name="CRITICAL_BATTERY_DOCKING"/>
          <SaveObstacles/>
          <ClearCostmap/>
          <Fallback name="CriticalNavOrStop">
            <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
            <!-- Docking failed — stay stopped, battery is critical -->
            <Sequence>
              <PublishHighLevelStatus state="0" state_name="CRITICAL_BATTERY_NAV_FAILED"/>
              <AlwaysSuccess/>
            </Sequence>
          </Fallback>
          <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
          <EndSession/>
          <ClearCommand/>
        </Sequence>

        <!-- ============================================================
             b. Mowing (COMMAND_START = 1)
             ============================================================ -->
        <Sequence name="MowingSequence">
          <IsCommand command="1"/>

          <!-- Wait for Nav2 to be fully active. Polled check: finishes in
               ~50 ms once the four lifecycle_manager_navigation nodes
               (bt_navigator / controller / planner / behavior) are all
               active; retries once per second for up to 60 s on ARM cold
               boot. Previously this was a hardcoded 30 s sleep inside the
               on-dock path only — which (a) wasted time when Nav2 was
               already ready, and (b) let the off-dock path issue goals
               into a half-up Nav2 stack, observed as bt_navigator stuck
               inactive → instant NavigateToPose rejections → skip-cascade
               drives the robot right out of the mowing area. -->
          <PublishHighLevelStatus state="2" state_name="PREFLIGHT_CHECK"/>
          <Fallback name="Nav2ReadyOrProceed">
            <RetryUntilSuccessful num_attempts="60" name="Nav2ReadyPoll">
              <Fallback>
                <Nav2Active timeout_sec="0.5"/>
                <Sequence>
                  <WaitForDuration duration_sec="1.0"/>
                  <AlwaysFailure/>
                </Sequence>
              </Fallback>
            </RetryUntilSuccessful>
            <!-- Timeout: proceed anyway with a warning. BoundaryGuard and
                 the emergency latch still apply; we'd rather let the run
                 fail fast at the first goal than freeze before starting. -->
            <AlwaysSuccess/>
          </Fallback>

          <!-- Undock: only if currently charging (on dock).
               If already undocked, skip entirely. -->
          <PublishHighLevelStatus state="2" state_name="UNDOCKING"/>
          <WaitForDuration duration_sec="1.0"/>
          <Fallback name="UndockOrSkip">
            <!-- Not on dock: the dock_yaw injection (hardware_bridge →
                 /gnss/heading → dock_yaw_to_set_pose.py) never fired, so
                 the global EKF has a random initial yaw. Drive forward 1 m
                 and derive yaw from the GPS track direction. Guarded by
                 yaw_seeded_this_session so a ReactiveSequence halt/resume
                 cycle does not re-trigger the forward drive mid-session. -->
            <Sequence name="NotDockedBranch">
              <Inverter><IsCharging/></Inverter>
              <PublishHighLevelStatus state="2" state_name="CALIBRATING_HEADING"/>
              <SeedYawFromMotion distance_m="1.0" speed_ms="0.2" timeout_sec="30.0"/>
              <!-- Drop stale obstacle marks projected during the pre-seed
                   forward drive: while the EKF yaw was random the scans
                   went into the costmap at the wrong orientation, and
                   obstacle_layer has observation_persistence=0 but only
                   clears via raytracing as the robot moves past. Clearing
                   now guarantees Nav2 sees a fresh view once the seed has
                   landed. -->
              <ClearCostmap/>
            </Sequence>
            <!-- On dock — wait for GPS, save map, then undock. IsCharging
                 gate ensures we only run the docked-undock path when the
                 robot is physically on the dock. Previously this branch
                 could fire as a fallback when NotDockedBranch failed,
                 which was dangerous — 1 m BackUp from a mid-polygon
                 pose frequently pushed us outside the boundary. -->
            <Sequence name="UndockSequence">
              <IsCharging/>
              <!-- Hard preflight gate — blocks until RTK Fixed (4) is
                   available, battery is OK, TF chain is healthy, and the
                   mowing/coverage services are up.
                   Non-RTK GPS gives σ ~20-50 cm, which is enough to push
                   the robot outside the polygon during transit and trigger
                   spurious boundary violations. Mowing at non-RTK is not
                   acceptable, so the check is strict: 120×1s retries then
                   the sequence fails and falls through to UndockFailed. -->
              <PublishHighLevelStatus state="2" state_name="PREFLIGHT_CHECK"/>
              <RetryUntilSuccessful num_attempts="120">
                <Fallback>
                  <PreFlightCheck min_battery="20.0" min_gps_fix_type="4" tf_timeout_sec="0.5"/>
                  <Sequence>
                    <WaitForDuration duration_sec="1.0"/>
                    <AlwaysFailure/>
                  </Sequence>
                </Fallback>
              </RetryUntilSuccessful>
              <PublishHighLevelStatus state="2" state_name="UNDOCKING"/>
              <RecordUndockStart/>
              <ClearCostmap/>
              <!-- BackUp via Nav2 behavior_server instead of
                   opennav_docking's UndockRobot: opennav's isDocked() uses
                   a geometric distance to the dock pose that is fragile
                   when RTK drifts briefly near the metal canopy. BackUp is
                   deterministic — reverse at the given speed for the
                   given distance. 1 m gives RTK ~5 s × 0.2 m/s of clean
                   displacement for CalibrateHeadingFromUndock to resolve
                   the initial heading accurately. -->
              <BackUp backup_dist="1.0" backup_speed="{undock_speed}"/>
              <!-- Wait for RTK Fixed after undock. The dock often has a
                   metal canopy that attenuates GPS; once the robot is 2 m
                   out the F9P should re-acquire quickly. Timeout proceeds
                   anyway at degraded precision rather than freeze. -->
              <WaitForGpsFix timeout_sec="20.0" min_fix_type="4"/>
              <!-- Refine the EKF yaw from the 1 m of GPS-verified backward
                   motion: heading = atan2(-dy, -dx). Sync, no extra motion.
                   Fails UndockSequence if GPS barely moved (robot stuck on
                   dock) so the BT retries the whole undock. -->
              <PublishHighLevelStatus state="2" state_name="CALIBRATING_HEADING"/>
              <CalibrateHeadingFromUndock min_displacement_m="0.5"/>
              <!-- Clear costmaps again after undock — dock structure must be
                   cleared before navigation starts. -->
              <ClearCostmap/>
            </Sequence>
            <!-- Undock failed — abort -->
            <Sequence name="UndockFailed">
              <StopMoving/>
              <PublishHighLevelStatus state="1" state_name="UNDOCK_FAILED"/>
              <ClearCommand/>
              <AlwaysFailure/>
            </Sequence>
          </Fallback>

          <!-- Record if it was raining at start — user chose to mow in rain -->
          <WasRainingAtStart/>

          <!-- Wait for obstacle detection before starting -->
          <WaitForDuration duration_sec="3.0"/>

          <!-- ════════════════════════════════════════════════════════
               CELL-BASED STRIP COVERAGE
               Each iteration: get next strip → transit → mow strip.
               No full-path pre-planning. Obstacles handled dynamically
               by Nav2 costmap. Progress tracked in mow_progress grid.
               ════════════════════════════════════════════════════════ -->
          <PublishHighLevelStatus state="2" state_name="MOWING"/>

          <ReactiveSequence name="MowingCommandGuard">
          <IsCommand command="1"/>

          <Fallback name="StripCoverageWithRecovery">

            <ReactiveSequence name="StripGuards">

              <!-- Reactive rain check.
                   IsNewRain returns FAILURE outright when rain_mode == 0
                   (operator disabled rain handling); it also debounces by
                   rain_debounce_sec before tripping. The dock round trip
                   only runs in rain_mode >= 2 ("dock-and-pause"); mode 1
                   ("pause-in-place") stops the blade and waits the rain
                   out where the robot stands. -->
              <Fallback name="RainGuard">
                <Inverter><IsNewRain/></Inverter>
                <Sequence name="RainHandle">
                  <SetMowerEnabled enabled="false"/>
                  <StopMoving/>
                  <Fallback name="RainDockBranch">
                    <Inverter><IsRainModeAtLeast mode="2"/></Inverter>
                    <Sequence name="RainDockSequence">
                      <PublishHighLevelStatus state="2" state_name="RAIN_DETECTED_DOCKING"/>
                      <ClearCostmap/>
                      <Fallback name="RainNavOrStay">
                        <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                        <AlwaysSuccess/>
                      </Fallback>
                    </Sequence>
                  </Fallback>
                  <PublishHighLevelStatus state="1" state_name="RAIN_WAITING"/>
                  <Fallback name="RainWaitOrTimeout">
                    <RetryUntilSuccessful num_attempts="1440">
                      <Fallback>
                        <Inverter><IsRainDetected/></Inverter>
                        <Sequence>
                          <WaitForDuration duration_sec="30.0"/>
                          <AlwaysFailure/>
                        </Sequence>
                      </Fallback>
                    </RetryUntilSuccessful>
                    <Sequence name="RainTimeout">
                      <PublishHighLevelStatus state="1" state_name="RAIN_TIMEOUT"/>
                      <ClearCommand/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                  <!-- Resume: only undock if we actually docked above
                       (rain_mode >= 2). Otherwise we stayed in place and
                       can resume directly. -->
                  <Fallback name="RainResume">
                    <Inverter><IsRainModeAtLeast mode="2"/></Inverter>
                    <Sequence name="RainResumeFromDock">
                      <IsResumeUndockAllowed max_attempts="3"/>
                      <PublishHighLevelStatus state="2" state_name="RESUMING_AFTER_RAIN"/>
                      <WaitForDuration duration_sec="1.0"/>
                      <Fallback name="RainResumeUndock">
                        <!-- BackUp instead of UndockRobot: opennav_docking isDocked()
                       uses geometric distance to dock pose which fails with
                       RTK drift near the dock canopy. BackUp reliably reverses
                       off the dock via Nav2 behavior_server. -->
                        <BackUp backup_dist="1.5" backup_speed="{undock_speed}"/>
                        <Sequence>
                          <RecordResumeUndockFailure/>
                          <ClearCommand/>
                          <AlwaysFailure/>
                        </Sequence>
                      </Fallback>
                    </Sequence>
                  </Fallback>
                  <PublishHighLevelStatus state="2" state_name="MOWING"/>
                </Sequence>
              </Fallback>

              <!-- Reactive battery check -->
              <Fallback name="BatteryGuard">
                <Inverter><NeedsDocking threshold="{battery_low_pct}"/></Inverter>
                <Sequence name="BatteryDockAndResume">
                  <SetMowerEnabled enabled="false"/>
                  <StopMoving/>
                  <PublishHighLevelStatus state="2" state_name="LOW_BATTERY_DOCKING"/>
                  <ClearCostmap/>
                  <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                  <PublishHighLevelStatus state="1" state_name="CHARGING"/>
                  <Fallback name="ChargeOrAbort">
                    <RetryUntilSuccessful num_attempts="960">
                      <Sequence>
                        <IsChargingProgressing/>
                        <Fallback>
                          <IsBatteryAbove threshold="{battery_full_pct}"/>
                          <Sequence>
                            <WaitForDuration duration_sec="30.0"/>
                            <AlwaysFailure/>
                          </Sequence>
                        </Fallback>
                      </Sequence>
                    </RetryUntilSuccessful>
                    <Sequence name="ChargerFailed">
                      <PublishHighLevelStatus state="1" state_name="CHARGER_FAILED"/>
                      <ClearCommand/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                  <IsResumeUndockAllowed max_attempts="3"/>
                  <PublishHighLevelStatus state="2" state_name="RESUMING_UNDOCKING"/>
                  <WaitForDuration duration_sec="1.0"/>
                  <Fallback name="ResumeUndockOrAbort">
                    <!-- BackUp instead of UndockRobot: opennav_docking isDocked()
                   uses geometric distance to dock pose which fails with
                   RTK drift near the dock canopy. BackUp reliably reverses
                   off the dock via Nav2 behavior_server. -->
              <BackUp backup_dist="1.5" backup_speed="{undock_speed}"/>
                    <Sequence>
                      <RecordResumeUndockFailure/>
                      <ClearCommand/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                  <PublishHighLevelStatus state="2" state_name="MOWING"/>
                </Sequence>
              </Fallback>

              <!-- Multi-area coverage loop (opennav_coverage migration).
                   Outer loop: iterate through all mowing areas.
                   Per area: PlanCoverageArea calls F2C on the remaining
                   un-mowed polygon (mow_progress excluded as holes), and
                   FollowStrip feeds the resulting path to FTCController.
                   On follow failure (collision wedge, FTC abort), the
                   recovery branches force a replan by returning FAILURE
                   to RetryUntilSuccessful; F2C re-plans on whatever is
                   left of the area, naturally resuming from where we
                   stopped.
                   GetNextUnmowedArea returns FAILURE when all areas are
                   done. PlanCoverageArea on a fully-mowed area emits an
                   empty path → FollowStrip FAILURE → 5 retries → outer
                   AreaUnreachable → AreaLoop advances. -->
              <Repeat num_cycles="100" name="AreaLoop">
                <Sequence name="MowOneArea">
                  <GetNextUnmowedArea area_index="{current_area_index}"/>
                  <!-- ONE PlanCoverageArea per area per session (no
                       replan), but multiple FollowStrip retries on the
                       SAME path. On a FollowStrip abort (collision_monitor
                       wedge, FTC goal-approach timeout, etc.), the next
                       FollowStrip tick re-sends ctx->current_strip_path
                       to FTCController, which picks the closest pose
                       to the robot via setPlan's nearest-pose search —
                       effectively "continue from where you left off"
                       without re-planning.
                       PlanCoverageArea FAILURE (empty path = area
                       already fully mowed) is captured by the outer
                       Fallback's AreaUnreachable branch so AreaLoop
                       advances cleanly. -->
                  <Fallback name="MowOrSkipArea">
                    <Sequence name="PlanThenFollow">
                      <PublishHighLevelStatus state="2" state_name="PLANNING"/>
                      <!-- headland_width_m=0.30 (was 0.20) insets the
                           F2C path 0.30 m from the operator polygon
                           edge. With wheel-PI motor model + production
                           IMU noise the post-pivot lateral drift can
                           hit 0.20 m; planning at 0.20 m inset pushed
                           the chassis center over the line on most
                           swath-end pivots and triggered boundary
                           recovery. 0.30 m gives a working margin. -->
                      <PlanCoverageArea
                          area_index="{current_area_index}"
                          operation_width_m="0.20"
                          headland_width_m="0.30"/>
                      <!-- Obstacle-aware transit to the coverage path start.
                           On a re-plan pass (AreaLoop re-enters an area that
                           still has un-mowed cells), the remaining region can
                           lie BEHIND a large obstacle the FTC follower cannot
                           reach in a straight carrot line — it would just
                           abort against the obstacle and the region behind it
                           would never be mowed (field: "toute une partie du
                           jardin pas faite"). TransitToStrip routes the robot
                           AROUND the obstacle via the Nav2 global planner
                           (Smac + the enabled global obstacle_layer), then
                           FollowStrip mows from there. Soft: if the start is
                           genuinely unreachable (walled off), fall through and
                           let FollowStrip try from the closest pose; the
                           no-progress guard in GetNextUnmowedArea then retires
                           the area after a pass with no coverage gain (so a
                           truly unreachable region doesn't loop forever, and a
                           DYNAMIC obstacle that later clears is picked up on a
                           subsequent pass). -->
                      <Fallback name="TransitToCoverageStart">
                        <Sequence name="TransitAroundObstacles">
                          <PublishHighLevelStatus state="2" state_name="TRANSIT"/>
                          <!-- Blade off while circumnavigating; FollowStrip
                               re-enables it when mowing resumes. -->
                          <SetMowerEnabled enabled="false"/>
                          <TransitToStrip/>
                        </Sequence>
                        <AlwaysSuccess/>
                      </Fallback>
                      <RetryUntilSuccessful num_attempts="5" name="FollowStripRetry">
                        <Fallback name="MowOrRecover">
                        <Sequence name="MowPath">
                          <PublishHighLevelStatus state="2" state_name="MOWING"/>
                          <FollowStrip/>
                        </Sequence>
                        <!-- Obstacle wedge recovery: BackUp + ClearCostmap
                             then bubble up FAILURE so RetryUntilSuccessful
                             re-ticks FollowStrip on the SAME path. FTC
                             will resync to the closest pose. -->
                        <Sequence name="StuckBackoff">
                          <IsObstacleStuck min_duration_sec="4.0"
                                           max_count="3"
                                           cooldown_sec="8.0"/>
                          <PublishHighLevelStatus state="2"
                                                  state_name="OBSTACLE_BACKOFF"/>
                          <SetMowerEnabled enabled="false"/>
                          <BackUp backup_dist="0.40" backup_speed="0.15"/>
                          <ClearCostmap/>
                          <AlwaysFailure/>
                        </Sequence>
                        <!-- Dynamic-obstacle clear gate: ClearCostmap +
                             brief wait, then re-tick FollowStrip on the
                             same path. -->
                        <Sequence name="DynamicObstacleSkip">
                          <WasRecentlyInCollisionStop max_age_sec="10.0"/>
                          <PublishHighLevelStatus state="2"
                                                  state_name="DYNAMIC_OBSTACLE_CLEARED"/>
                          <SetMowerEnabled enabled="false"/>
                          <StopMoving/>
                          <ClearCostmap/>
                          <WaitForDuration duration_sec="1.0"/>
                          <AlwaysFailure/>
                        </Sequence>
                        </Fallback>
                      </RetryUntilSuccessful>
                    </Sequence>
                    <!-- Fallback to here on PlanCoverageArea FAILURE
                         (empty path / planning error) OR after the 5
                         FollowStrip retries are exhausted. Either way,
                         mark the area attempted and advance. -->
                    <Sequence name="AreaUnreachable">
                      <PublishHighLevelStatus state="2" state_name="AREA_UNREACHABLE"/>
                      <SetMowerEnabled enabled="false"/>
                      <StopMoving/>
                      <AlwaysSuccess/>
                    </Sequence>
                  </Fallback>
                </Sequence>
              </Repeat>

            </ReactiveSequence>

            <!-- Coverage failed — dock gracefully -->
            <Sequence name="FailedCoverageDock">
              <SetMowerEnabled enabled="false"/>
              <PublishHighLevelStatus state="2" state_name="COVERAGE_FAILED_DOCKING"/>
              <ClearCostmap/>
              <Fallback name="FailedCoverageNavOrStop">
                <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                <Sequence>
                  <PublishHighLevelStatus state="0" state_name="NAV_TO_DOCK_FAILED"/>
                  <AlwaysSuccess/>
                </Sequence>
              </Fallback>
              <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
              <EndSession/>
              <ClearCommand/>
            </Sequence>
          </Fallback>
          </ReactiveSequence>

          <!-- Mowing complete — dock. Mirrors HomeSequence's robustness:
               * ReactiveSequence re-checks IsCommand(1) every tick, so a
                 new operator command (HOME, cancel, delete-maps, …) halts
                 the in-flight DockRobot instead of holding the BT hostage
                 for the full retry budget. The plain parent <Sequence>
                 only evaluates IsCommand(1) on entry, so without this
                 wrapper the terminal dock was un-interruptible — the
                 "Mowing Complete, nothing responds" lockup.
               * ReactiveFallback(IsCharging) short-circuits the moment the
                 charging pins engage, even if opennav_docking hasn't
                 concluded yet (GPS drift near the dock).
               * Fallback(DockRobot / NAV_TO_DOCK_FAILED+AlwaysSuccess)
                 guarantees we fall through to ClearCommand even when the
                 dock action ultimately fails — otherwise current_command
                 stayed latched at 1 and the BT re-entered the terminal
                 dock forever.
               ClearCostmap runs after SaveObstacles: persist what we
               learned, then wipe stale marks so the nav-to-staging
               approach isn't walled off by residual obstacle cells (fresh
               scans re-populate real obstacles immediately). -->
          <ReactiveSequence name="MowingCompleteSequence">
            <IsCommand command="1"/>
            <Sequence name="MowingCompleteAction">
              <SetMowerEnabled enabled="false"/>
              <PublishHighLevelStatus state="1" state_name="MOWING_COMPLETE"/>
              <SaveObstacles/>
              <ClearCostmap/>
              <ReactiveFallback name="MowingCompleteOrDocked">
                <IsCharging/>
                <Fallback name="MowingCompleteDockOrStop">
                  <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                  <Sequence>
                    <PublishHighLevelStatus state="0" state_name="NAV_TO_DOCK_FAILED"/>
                    <AlwaysSuccess/>
                  </Sequence>
                </Fallback>
              </ReactiveFallback>
              <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
              <EndSession/>
              <ClearCommand/>
            </Sequence>
          </ReactiveSequence>
        </Sequence>

        <!-- ============================================================
             c. Home (COMMAND_HOME = 2)
             Wrapped in a ReactiveSequence with IsCommand(2) at the top:
             if the user sends any other command (including 0 / cancel)
             while DockRobot is mid-flight, the guard returns FAILURE and
             the running action is halted via onHalted() — so the BT does
             not hold the user hostage for up to ~5 min of dock retries.
             The inner <Sequence> keeps memory semantics so StopMoving and
             the other one-shot setup steps don't re-fire each tick.
             ============================================================ -->
        <ReactiveSequence name="HomeSequence">
          <IsCommand command="2"/>
          <Sequence name="HomeAction">
            <SetMowerEnabled enabled="false"/>
            <StopMoving/>
            <!-- ReactiveFallback re-evaluates IsCharging every tick. If the
                 charging pins engage mid-DockRobot (robot physically reaches
                 the dock but opennav_docking hasn't concluded yet — common
                 with GPS drift near the dock), IsCharging returns SUCCESS,
                 the running DockRobot is halted, and we fall through to
                 IDLE_DOCKED. A plain Fallback would stick on the RUNNING
                 DockRobot child until it terminates on its own (up to
                 ~5 min of retries), leaving the BT stuck in RETURNING_HOME
                 even though the robot is already charging. -->
            <ReactiveFallback name="HomeOrAlreadyDocked">
              <IsCharging/>
              <Sequence name="NavigateHome">
                <PublishHighLevelStatus state="2" state_name="RETURNING_HOME"/>
                <SaveObstacles/>
                <!-- Wipe stale obstacle cells so the nav-to-staging dock
                     approach isn't walled off (see MowingCompleteSequence). -->
                <ClearCostmap/>
                <Fallback name="HomeNavOrStop">
                  <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                  <Sequence>
                    <PublishHighLevelStatus state="0" state_name="NAV_TO_DOCK_FAILED"/>
                    <AlwaysSuccess/>
                  </Sequence>
                </Fallback>
              </Sequence>
            </ReactiveFallback>
            <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
            <EndSession/>
            <ClearCommand/>
          </Sequence>
        </ReactiveSequence>

        <!-- ============================================================
             d. Recording (COMMAND_S1 = 3 = COMMAND_RECORD_AREA)
             User drives robot along boundary. The RecordArea node
             records positions at 2 Hz and publishes a live trajectory
             preview. When the user presses "Finish" (command 5) the
             trajectory is simplified with Douglas-Peucker and saved
             as a mowing area. "Cancel" (command 6) discards it.
             ============================================================ -->
        <!-- ReactiveSequence with a Fallback guard accepting commands 3/5/6.
             History: a plain <Sequence> here re-evaluated IsCommand(3) every
             tick, so the moment the user pressed "Finish" (command 5) the
             guard failed and the sequence halted RecordArea via onHalted(),
             which cleared trajectory_ before save_area() ever ran — every
             finished recording silently dropped its points. We previously
             switched to <SequenceWithMemory>, but combined with the
             non-reactive parent <Fallback name="MainLogic"> that introduced
             a worse regression: after RecordArea returned FAILURE on cancel,
             the memorised guard plus the parent's tick-from-running-child
             behaviour caused the sequence to silently re-enter RecordArea
             without a new command — and after a few cycles the BT itself
             went silent (mutex contention with the HLC service handler that
             also writes ctx->current_command).
             The right shape is reactive WITH a widened guard: re-evaluate
             every tick, but accept any of 3 (start), 5 (finish), 6 (cancel)
             so RecordArea stays RUNNING long enough for its onRunning()
             handler in recording_nodes.cpp:73 to see the finish/cancel
             command, save (or discard) the polygon, clear current_command,
             and return SUCCESS/FAILURE cleanly. Command 2 (HOME) is
             deliberately NOT in the guard — that triggers a halt and
             fallthrough to HomeSequence, which is the desired
             "abort recording and dock" behaviour. -->
        <ReactiveSequence name="RecordingSequence">
          <Fallback name="RecordingCommandGuard">
            <IsCommand command="3"/>
            <IsCommand command="5"/>
            <IsCommand command="6"/>
          </Fallback>
          <PublishHighLevelStatus state="3" state_name="RECORDING"/>
          <RecordArea
            simplification_tolerance="0.2"
            min_vertices="3"
            min_area="1.0"
            record_rate_hz="2.0"
            is_exclusion_zone="false"/>
          <PublishHighLevelStatus state="1" state_name="RECORDING_COMPLETE"/>
          <EndSession/>
          <ClearCommand/>
        </ReactiveSequence>

        <!-- ============================================================
             e. Manual Mowing (COMMAND_MANUAL_MOW = 7)
             Teleop via /cmd_vel_teleop (twist_mux priority).
             Collision_monitor remains active. GPS/SLAM continues.

             Blade is enabled here by the BT (not the GUI) because the
             firmware forcibly zeroes target_blade_on_off whenever its
             mirrored HL mode is IDLE/NULL (cpp_main.cpp on_hl_state).
             The GUI used to send mow_enabled=1 immediately after
             Command=7, but the firmware had not yet received the
             MANUAL_MOWING mode update, so it zeroed the blade. Driving
             the blade on AFTER PublishHighLevelStatus(4) guarantees the
             firmware sees MANUAL_MOWING first, then the blade command.

             ReactiveSequence is used deliberately: on every tick it
             re-evaluates IsCommand from the first child, even while
             WaitForDuration is running. When the user presses Home
             (command changes from 7 to 2), IsCommand returns FAILURE,
             the ReactiveSequence halts WaitForDuration and returns
             FAILURE, allowing the Fallback to select HomeSequence on
             the very next tick. On exit, the following sequence (Home
             or Idle) calls SetMowerEnabled(false) which stops the blade.
             ============================================================ -->
        <ReactiveSequence name="ManualMowingSequence">
          <IsCommand command="7"/>
          <PublishHighLevelStatus state="4" state_name="MANUAL_MOWING"/>
          <SetMowerEnabled enabled="true"/>
          <WaitForDuration duration_sec="0.5"/>
        </ReactiveSequence>

        <!-- ============================================================
             f. Idle default
             ============================================================ -->
        <Sequence name="IdleSequence">
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="1" state_name="IDLE"/>
          <WaitForDuration duration_sec="0.5"/>
        </Sequence>

      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>

</root>
