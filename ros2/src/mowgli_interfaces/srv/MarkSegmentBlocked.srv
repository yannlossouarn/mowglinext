# MarkSegmentBlocked — called by the BT after FollowSegment FAILURE
# to charge the cells along the failed path with a "fail_count" tick.
# When a cell's fail_count exceeds dead_promote_threshold (default 3)
# the cell is promoted to CellType::LAWN_DEAD and skipped by all
# subsequent GetNextSegment calls. The DEAD classification decays
# back to LAWN over time (configured by map_server's dead_decay_rate
# parameter) so a transient blocker doesn't permanently sterilise
# part of the lawn.
#
# Path C, 2026-05-01.

# The path that the robot tried to follow but couldn't complete.
# Map frame. The handler samples mow_progress along this path at
# resolution_ steps and bumps fail_count for each unmowed cell on
# the path that lies inside the area polygon.
nav_msgs/Path failed_path
# Area whose mowing was being attempted. fail_count is bumped only
# for cells inside this area's polygon.
uint32 area_index
---
bool success
# Number of cells whose fail_count was incremented this call.
uint32 cells_marked_blocked
# Number of cells that crossed dead_promote_threshold and were
# promoted to LAWN_DEAD this call.
uint32 cells_promoted_dead
