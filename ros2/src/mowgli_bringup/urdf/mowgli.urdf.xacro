<?xml version="1.0"?>
<!--
  mowgli.urdf.xacro
  URDF/Xacro description of the Mowgli robot mower.
  Approximate dimensions based on YardForce Classic 500.

  Coordinate conventions (REP-103):
    x  forward
    y  left
    z  up

  Key dimensions (from real YardForce Classic 500 URDF):
    Base:          0.54 m long, 0.40 m wide, 0.19 m high
    Drive wheels:  radius 0.093 m (186 mm dia), width 0.04 m, track 0.325 m (rear)
    Front casters: radius 0.03 m, width 0.03 m
    Blade disc:    radius 0.09 m, height 0.01 m (centred under base)
    Wheel ground clearance sets base_link at z = drive_wheel_radius = 0.093 m
    above base_footprint.
-->
<robot name="mowgli" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================================================================
       Configurable arguments (can be overridden via xacro command-line)
       ================================================================ -->
  <!-- LiDAR mount defaults match mowgli_robot.yaml as of 2026-04-26
       (lidar at base centre, ~π rotated mount). Launch overrides these
       at runtime from the operator's calibrated yaml. -->
  <xacro:arg name="lidar_x"   default="0.0"/>
  <xacro:arg name="lidar_y"   default="0.024"/>
  <xacro:arg name="lidar_z"   default="0.22"/>
  <xacro:arg name="lidar_yaw" default="3.1408"/>

  <xacro:arg name="imu_x"     default="0.18"/>
  <xacro:arg name="imu_y"     default="0.0"/>
  <xacro:arg name="imu_z"     default="0.095"/>
  <!-- Full 3-axis mounting rotation (roll, pitch, yaw) in radians.
       yaw=only handles chip-Z ≡ robot-Z mounts. Upside-down, side-mounted,
       or tilted installations require roll/pitch too. Firmware reports the
       WT901's chip-native axes unchanged, so this URDF rotation is the
       sole correction. -->
  <xacro:arg name="imu_roll"  default="0.0"/>
  <xacro:arg name="imu_pitch" default="0.0"/>
  <xacro:arg name="imu_yaw"   default="0.0"/>

  <xacro:arg name="gps_x"     default="0.3"/>
  <xacro:arg name="gps_y"     default="0.0"/>
  <xacro:arg name="gps_z"     default="0.20"/>

  <!-- Chassis shape (all from mowgli_robot.yaml via launch file) -->
  <xacro:arg name="chassis_length"   default="0.60"/>
  <xacro:arg name="chassis_width"    default="0.40"/>
  <xacro:arg name="chassis_height"   default="0.19"/>
  <xacro:arg name="chassis_center_x" default="0.20"/>
  <xacro:arg name="wheel_radius"     default="0.093"/>
  <xacro:arg name="wheel_width"      default="0.04"/>
  <xacro:arg name="wheel_track"      default="0.325"/>
  <xacro:arg name="wheel_x_offset"   default="0.0"/>
  <xacro:arg name="caster_radius"    default="0.03"/>
  <xacro:arg name="caster_track"     default="0.36"/>
  <xacro:arg name="blade_radius"     default="0.09"/>

  <!-- ================================================================
       Properties (resolved from args — all shape from config)
       ================================================================ -->
  <xacro:property name="base_length"      value="$(arg chassis_length)"/>
  <xacro:property name="base_width"       value="$(arg chassis_width)"/>
  <xacro:property name="base_height"      value="$(arg chassis_height)"/>
  <xacro:property name="chassis_cx"       value="$(arg chassis_center_x)"/>

  <xacro:property name="wheel_radius"     value="$(arg wheel_radius)"/>
  <xacro:property name="wheel_width"      value="$(arg wheel_width)"/>
  <xacro:property name="wheel_track"      value="$(arg wheel_track)"/>
  <xacro:property name="wheel_mass"       value="0.5"/>
  <xacro:property name="wheel_x_offset"   value="$(arg wheel_x_offset)"/>

  <xacro:property name="caster_radius"    value="$(arg caster_radius)"/>
  <xacro:property name="caster_width"     value="0.03"/>
  <xacro:property name="caster_mass"      value="0.2"/>
  <!-- Casters near front edge of chassis -->
  <xacro:property name="caster_x_offset"  value="${chassis_cx + base_length/2.0 - caster_radius}"/>
  <xacro:property name="caster_track"     value="$(arg caster_track)"/>

  <xacro:property name="base_mass"        value="8.76"/>

  <xacro:property name="blade_radius"     value="$(arg blade_radius)"/>
  <xacro:property name="blade_height"     value="0.01"/>
  <xacro:property name="blade_mass"       value="0.3"/>

  <!-- Derived: base_link is wheel_radius above ground -->
  <xacro:property name="base_z_offset"   value="${wheel_radius}"/>

  <!-- ================================================================
       Inertia macros
       ================================================================ -->

  <!-- Solid cylinder: axis along z -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(1.0/12.0)*m*(3*r*r + h*h)}"
        ixy="0" ixz="0"
        iyy="${(1.0/12.0)*m*(3*r*r + h*h)}"
        iyz="0"
        izz="${0.5*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid cylinder: axis along y (for wheels) -->
  <xacro:macro name="wheel_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <!-- Rotate the standard cylinder inertia so the rolling axis is y -->
      <inertia
        ixx="${(1.0/12.0)*m*(3*r*r + h*h)}"
        ixy="0" ixz="0"
        iyy="${0.5*m*r*r}"
        iyz="0"
        izz="${(1.0/12.0)*m*(3*r*r + h*h)}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid box -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(1.0/12.0)*m*(y*y + z*z)}"
        ixy="0" ixz="0"
        iyy="${(1.0/12.0)*m*(x*x + z*z)}"
        iyz="0"
        izz="${(1.0/12.0)*m*(x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <!-- ================================================================
       base_footprint  (on the ground plane)
       ================================================================ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_z_offset}" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================
       base_link  (centre of rear drive wheel axis at wheel axle height)
       ================================================================ -->
  <link name="base_link">
    <visual>
      <!-- Chassis centre offset forward from wheel axis -->
      <origin xyz="${chassis_cx} 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="mowgli_green">
        <color rgba="0.18 0.55 0.18 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="${chassis_cx} 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}"
                       x="${base_length}"
                       y="${base_width}"
                       z="${base_height}"/>
  </link>

  <!-- ================================================================
       Drive wheel macro
       ================================================================ -->
  <xacro:macro name="drive_wheel" params="side y_reflect">
    <link name="${side}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:wheel_inertia m="${wheel_mass}"
                           r="${wheel_radius}"
                           h="${wheel_width}"/>
    </link>

    <joint name="${side}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${side}_wheel_link"/>
      <!-- Drive wheels at base_link origin -->
      <origin xyz="${wheel_x_offset} ${y_reflect * wheel_track/2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- Gazebo friction for realistic wheel contact -->
    <gazebo reference="${side}_wheel_link">
      <mu1>1.0</mu1>
      <mu2>0.5</mu2>
      <kp>1e6</kp>
      <kd>1.0</kd>
      <minDepth>0.001</minDepth>
    </gazebo>
  </xacro:macro>

  <xacro:drive_wheel side="left"  y_reflect="1"/>
  <xacro:drive_wheel side="right" y_reflect="-1"/>

  <!-- ================================================================
       Front caster wheel macro (two front casters like real robot)
       ================================================================ -->
  <xacro:macro name="front_caster" params="side y_reflect">
    <link name="front_${side}_caster_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${caster_radius}" length="${caster_width}"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${caster_radius}" length="${caster_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${caster_mass}"/>
        <inertia
          ixx="${(2.0/5.0)*caster_mass*caster_radius*caster_radius}"
          ixy="0" ixz="0"
          iyy="${(2.0/5.0)*caster_mass*caster_radius*caster_radius}"
          iyz="0"
          izz="${(2.0/5.0)*caster_mass*caster_radius*caster_radius}"/>
      </inertial>
    </link>

    <joint name="front_${side}_caster_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="front_${side}_caster_link"/>
      <!-- Front casters: forward of centre, z at ground level -->
      <origin xyz="${caster_x_offset} ${y_reflect * caster_track/2} ${-wheel_radius + caster_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <gazebo reference="front_${side}_caster_link">
      <mu1>0.0</mu1>
      <mu2>0.0</mu2>
      <kp>1e6</kp>
      <kd>1.0</kd>
    </gazebo>
  </xacro:macro>

  <xacro:front_caster side="left"  y_reflect="1"/>
  <xacro:front_caster side="right" y_reflect="-1"/>

  <!-- ================================================================
       Blade disc  (centred under base, just below chassis)
       ================================================================ -->
  <link name="blade_link">
    <visual>
      <origin xyz="0 0 ${blade_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${blade_radius}" length="${blade_height}"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${blade_radius}" length="${blade_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${blade_mass}"
                            r="${blade_radius}"
                            h="${blade_height}"/>
  </link>

  <joint name="blade_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="blade_link"/>
    <!-- Blade disc centred under chassis -->
    <origin xyz="${chassis_cx} 0 ${-wheel_radius + 0.05}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ================================================================
       IMU link  (centre of base)
       ================================================================ -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
      <material name="blue_chip">
        <color rgba="0.0 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="$(arg imu_x) $(arg imu_y) $(arg imu_z)"
            rpy="$(arg imu_roll) $(arg imu_pitch) $(arg imu_yaw)"/>
  </joint>

  <!-- ================================================================
       GPS link  (top centre of base)
       ================================================================ -->
  <link name="gps_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="gps_link"/>
    <origin xyz="$(arg gps_x) $(arg gps_y) $(arg gps_z)" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================
       LiDAR link  (front-top of base, 0.20 m forward, 0.25 m high)
       ================================================================ -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="dark_sensor">
        <color rgba="0.15 0.15 0.15 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.18"/>
      <inertia ixx="1e-4" ixy="0" ixz="0"
               iyy="1e-4" iyz="0"
               izz="1e-4"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <!-- Mounted on top front of chassis — position configurable via xacro args -->
    <origin xyz="$(arg lidar_x) $(arg lidar_y) $(arg lidar_z)" rpy="0 0 $(arg lidar_yaw)"/>
  </joint>

  <!-- ================================================================
       Gazebo simulation
       ================================================================ -->
  <!-- Simulation physics and sensors are defined in the standalone Ignition
       Gazebo model: mowgli_simulation/models/mowgli_mower/model.sdf
       This URDF provides TF frames and RViz visualisation only. -->

</robot>
